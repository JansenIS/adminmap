{
  "name": "river_logistics",
  "title": "River Logistics Sidecar Module",
  "version": "1.0.0",
  "author": "OpenAI",
  "type": "sidecar",
  "requires": {
    "php": ">=8.0",
    "extensions": ["json", "mbstring", "gd"]
