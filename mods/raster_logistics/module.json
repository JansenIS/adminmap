{
  "name": "raster_logistics",
  "title": "Raster Logistics Unified Overlay",
  "version": "2.0.0-unified",
  "type": "sidecar-module",
  "description": "Unified land + river + marine raster logistics overlay for adminmap. Reads sidecar river and marine modules, merges them into one route graph, and writes only runtime overlays.",
  "safe_remove": true,
  "runtime_dir": "data/module_runtime/raster_logistics",
  "requires": [
    "php-gd"
  ],
  "optional_modules": [
    "mods/river_logistics",
    "mods/marine_provinces"
  ],
  "id": "raster_logistics",
  "entry_ui_alt": "sidecar_admin.html?module=raster_logistics",
  "api": {
    "run": "mods/raster_logistics/api/run.php"
  },
  "supports": {
    "dry_run": true,
    "attach_to_turn": false,
    "download": true,
    "cleanup": true
  },
  "outputs": [
    "network.json",
    "summary.json"
  ],
  "tags": [
    "logistics",
    "raster",
    "unified"
  ]
}
